# OpenAI API key for DeepEval judge model
OPENAI_API_KEY=sk-your-key-here

# Optional: override judge model (default: gpt-4o)
# DEEPEVAL_JUDGE_MODEL=gpt-4o

# Optional: override test target model (default: gpt-4o-mini)
# TEST_MODEL=gpt-4o-mini

# Local test results storage
DEEPEVAL_RESULTS_FOLDER=./test-results
